MONGO_DB_NAME=lost_found_db
# Standard Atlas SRV URI. Use this when your network allows SRV DNS lookups.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.lg5y6u3.mongodb.net/?appName=Cluster0
# Preferred fallback when SRV DNS is blocked or timing out. The app will try this first if set.
MONGO_DIRECT_URI=mongodb://<username>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/?ssl=true&replicaSet=atlas-<cluster-shard>&authSource=admin&retryWrites=true&w=majority&appName=Cluster0
# Optional: force public DNS resolvers for SRV lookups on networks where local DNS times out.
MONGO_DNS_RESOLVERS=1.1.1.1,8.8.8.8
MONGO_DNS_TIMEOUT_SECONDS=5
SECRET_KEY=<your-secret-key>
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Environment mode (development or production)
ENV=development

# Redis URL for rate limiter (recommended for production)
# Local: redis://localhost:6379
# Render: use Render's Redis service URL
REDIS_URL=redis://localhost:6379

# Email provider options:
# EMAIL_PROVIDER=auto    -> uses Resend if configured, else SMTP/Gmail fallback
# EMAIL_PROVIDER=resend  -> uses Resend HTTPS API
# EMAIL_PROVIDER=smtp    -> uses generic SMTP credentials below
EMAIL_PROVIDER=auto
EMAIL_FROM_NAME=CampusFind

# Resend API setup
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM_EMAIL=<verified-sender@your-domain.com>

# Generic SMTP fallback
# Gmail example:
# EMAIL=campusfind.lnf@gmail.com
# EMAIL_PASS=<gmail-app-password>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=campusfind.lnf@gmail.com
SMTP_PASSWORD=<gmail-app-password>
SMTP_FROM_EMAIL=campusfind.lnf@gmail.com
