# Flask Configuration
SECRET_KEY=your_secret_key_here
DEBUG=False

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
# OR if using direct connection:
MONGO_DIRECT_URI=mongodb://hostname:27017/
MONGO_DB_NAME=lost_found_db

# Email Configuration (EMAIL OTP SETTINGS)
# ==========================================
SEND_EMAIL_OTP=True

# Gmail Configuration (Recommended - Easy Setup)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_gmail@gmail.com
# For Gmail: Use APP PASSWORD (not your gmail password)
# Generate here: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=your_gmail_app_password

# OR use any SMTP provider (Mailtrap, Sendgrid, AWS SES, etc.)
# MAIL_SERVER=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_username
# MAIL_PASSWORD=your_password

# Email From Address
MAIL_DEFAULT_SENDER=noreply@lostandfound.com

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Admin and Staff Secrets
ADMIN_SECRET=your_admin_secret
STAFF_SECRET=your_staff_secret
